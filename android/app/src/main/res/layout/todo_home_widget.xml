<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent" android:padding="12dp">
    <TextView android:id="@+id/widget_title" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="My Tasks"
        android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
    <TextView android:id="@+id/widget_tasks" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:textSize="12sp"/>
    <TextView android:id="@+id/widget_footer" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="11sp"/>
</LinearLayout>
